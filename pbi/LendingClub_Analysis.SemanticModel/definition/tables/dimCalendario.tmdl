	partition dimCalendario = calculated
		mode: import
		source = ```
				
				-- 1. Busca dinamicamente os anos limites com base na sua coluna de emissão
				VAR _AnoMinimo = YEAR(MIN('public vw_lending_club_powerbi'[data_emissao]))
				VAR _AnoMaximo = YEAR(MAX('public vw_lending_club_powerbi'[data_emissao]))
				
				-- 2. Cria o intervalo de datas cobrindo os anos cheios (Boa Prática para não quebrar o DAX)
				VAR _CalendarioBase = 
				    CALENDAR(
				        DATE(_AnoMinimo, 1, 1), 
				        DATE(_AnoMaximo, 12, 31)
				    )
				
				RETURN
				ADDCOLUMNS(
				    _CalendarioBase,
				    "Ano", YEAR([Date]),
				    "Trimestre Num", QUARTER([Date]),
				    "Trimestre", "T" & QUARTER([Date]),
				    "Mês Num", MONTH([Date]),
				    "Mês Nome", FORMAT([Date], "MMMM", "pt-PT"),
				    "Mês Abrev", UPPER(LEFT(FORMAT([Date], "MMM", "pt-PT"), 3)),
				    "Ano Mês Num", (YEAR([Date]) * 100) + MONTH([Date]),
				    "Ano Mês", FORMAT([Date], "yyyy/MM"),
				    "Dia da Semana Num", WEEKDAY([Date], 2), -- 1 para Segunda, 7 para Domingo
				    "Dia da Semana", FORMAT([Date], "dddd", "pt-PT")
				)
				```

	annotation PBI_Id = 890382b9b2af445f8bf092f56819f50b

